---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- HERO SECTION -->
  <section style="position:relative;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;">
    
    <!-- Background Image -->
    <div style="position:absolute;inset:0;background-image:url('/bg-museum.jpg');background-size:cover;background-position:center;filter:brightness(0.4);"></div>
    
    <!-- Overlay -->
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));"></div>

    <!-- Content -->
    <div style="position:relative;text-align:center;padding:2rem;">
      <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;opacity:0.6;margin-bottom:1.5rem;">BSME Studio · Group 5</p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(4rem,10vw,9rem);font-weight:300;line-height:0.9;letter-spacing:0.05em;margin-bottom:2.5rem;">
        COLONIAL<br/>INFLUENCE
      </h1>
      <a href="/artworks" style="display:inline-block;border:1px solid rgba(245,240,232,0.6);padding:0.85rem 2.5rem;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;color:#f5f0e8;text-decoration:none;transition:all 0.3s;">
        START VIRTUAL TOUR
      </a>
    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;opacity:0.4;">
      <span style="font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;">Scroll</span>
      <div style="width:1px;height:3rem;background:linear-gradient(to bottom, #f5f0e8, transparent);"></div>
    </div>
  </section>

  <!-- INTRO SECTION -->
  <section style="max-width:800px;margin:8rem auto;padding:0 2rem;text-align:center;">
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;margin-bottom:1.5rem;">A Journey Through Art & History</h2>
    <p style="font-size:0.95rem;line-height:1.9;opacity:0.7;">
      Explore five remarkable artworks that capture the complexity of colonial rule in the Philippines — from monumental sculpture to sweeping historical painting. Each piece tells a story of power, identity, and cultural exchange.
    </p>
  </section>
</Layout>