---
import '../styles/global.css';

const { title = 'Colonial Influence' } = Astro.props;
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Artworks', href: '/artworks' },
  { label: 'Artists', href: '/artists' },
  { label: 'About', href: '/about' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Colonial Influence</title>
  </head>
  <body>
    <nav style="position:fixed;top:0;left:0;right:0;z-index:50;padding:1.5rem 3rem;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);">
      <a href="/" style="font-family:'Cormorant Garamond',serif;font-size:1.25rem;letter-spacing:0.15em;color:#f5f0e8;text-decoration:none;">
        COLONIAL INFLUENCE
      </a>
      <ul style="display:flex;gap:2.5rem;list-style:none;">
        {navLinks.map(link => (
          <li>
            <a href={link.href} style="font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;color:#f5f0e8;text-decoration:none;opacity:0.8;">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <slot />
  </body>
</html>